[Unit]
Description=commaBot webhook pipeline (Docker Compose)
After=network-online.target docker.service
Requires=docker.service

[Service]
Type=simple
User=carls
WorkingDirectory=/home/carls/commabot-infrastructure
ExecStart=/usr/bin/docker compose up
ExecStop=/usr/bin/docker compose down
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
