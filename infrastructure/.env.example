# commaBot environment configuration
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# --- GitHub App ---
# The webhook secret you configured when creating the GitHub App
WEBHOOK_SECRET=

# Your GitHub App's ID (visible in the GitHub App settings page)
GITHUB_APP_ID=

# Path to the GitHub App's private key (inside the container)
GITHUB_APP_PRIVATE_KEY_PATH=/app/commabot.private-key.pem

# The installation ID for your repo (from the App installation URL)
GITHUB_INSTALLATION_ID=

# --- Letta Code ---
# Your Letta API key (from https://letta.com)
LETTA_API_KEY=

# The conversation ID that the webhook pipeline routes to
# (create a conversation in Letta, then set this to its ID)
COMMA_WEBHOOK_CONVERSATION_ID=

# --- Paths ---
# Working directory inside the container (where the target repo is mounted)
COMMA_CWD=/home/commabot/comma

# --- Channel adapter ---
# Port for the Letta Code channel adapter (internal, between Flask and Letta)
SDK_PORT=3000
SDK_RELAY_URL=http://127.0.0.1:3000/relay
